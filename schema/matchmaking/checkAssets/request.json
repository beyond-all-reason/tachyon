{
    "$id": "https://schema.beyondallreason.dev/tachyon/matchmaking/checkAssets/request.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MatchmakingCheckAssetsRequest",
    "tachyon": {
        "source": "server",
        "target": "user",
        "scopes": ["tachyon.lobby"]
    },
    "type": "object",
    "properties": {
        "type": { "const": "request" },
        "messageId": { "type": "string" },
        "commandId": { "const": "matchmaking/checkAssets" },
        "data": {
            "title": "MatchmakingCheckAssetsRequestData",
            "type": "object",
            "properties": {
                "queueId": { "type": "string" },
                "version": { "type": "string" },
                "engines": { "type": "array", "items": { "type": "string" } },
                "game": { "type": "string" },
                "maps": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["queueId", "version", "engines", "game", "maps"]
        }
    },
    "required": ["type", "messageId", "commandId", "data"]
}
