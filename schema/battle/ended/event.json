{
    "$id": "https://schema.beyondallreason.dev/tachyon/battle/ended/event.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "BattleEndedEvent",
    "tachyon": {
        "source": "server",
        "target": "user",
        "scopes": ["tachyon.lobby"]
    },
    "type": "object",
    "properties": {
        "type": { "const": "event" },
        "messageId": { "type": "string" },
        "commandId": { "const": "battle/ended" },
        "data": {
            "title": "BattleEndedEventData",
            "type": "object",
            "properties": {
                "battleId": { "$ref": "../../definitions/battleId.json" },
                "players": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "userId": {
                                "$ref": "../../definitions/userId.json"
                            },
                            "allyTeam": { "type": "string" },
                            "team": { "type": "string" },
                            "player": { "type": "string" }
                        },
                        "required": ["userId", "allyTeam", "team", "player"]
                    }
                },
                "spectators": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "userId": {
                                "$ref": "../../definitions/userId.json"
                            }
                        },
                        "required": ["userId"]
                    }
                },
                "winningAllyTeamIds": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            },
            "required": [
                "battleId",
                "players",
                "spectators",
                "winningAllyTeamIds"
            ]
        }
    },
    "required": ["type", "messageId", "commandId", "data"]
}
